# =============================================================================
# .env.example – Environment variable template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#
#   cp .env.example .env
#   # edit .env with your actual values
#
# Machine layout (dual-stack IPv4 + IPv6):
#   PC 1 (Node A) – Minecraft Primary  + Velocity Proxy 1  – 192.168.1.10 / fd00::10
#   PC 2 (Node B) – Minecraft Backup   + Velocity Proxy 2  – 192.168.1.11 / fd00::11
#   PC 3 (NFS)    – Dedicated storage  (no game processes)  – 192.168.1.5  / fd00::5
#
# Use ULA (Unique Local Addresses, fd00::/8) for the internal IPv6 network.
# Replace with your actual GUA (Global Unicast) or ULA prefix as needed.
# =============================================================================

# ── Velocity ──────────────────────────────────────────────────────────────────
# Shared secret between Velocity proxies and Minecraft backends.
# Generate with:  openssl rand -hex 16
VELOCITY_SECRET=CHANGE_ME_32_CHAR_SECRET_HERE

# ── Network – IPv4 ────────────────────────────────────────────────────────────
# Public IPv4 Virtual IP managed by Keepalived (what players / DNS point to).
# This VIP floats between Node A and Node B.
PROXY_VIP=192.168.1.200

# Real IPv4 address of Node A (primary Minecraft + Proxy 1)
NODE_A_IP=192.168.1.10

# Real IPv4 address of Node B (backup Minecraft + Proxy 2)
NODE_B_IP=192.168.1.11

# IPv4 address of the dedicated NFS storage server (PC 3)
NFS_SERVER_IP=192.168.1.5

# ── Network – IPv6 ────────────────────────────────────────────────────────────
# Public IPv6 Virtual IP managed by Keepalived (VRRPv3).
# Players with IPv6 connectivity use this address directly.
PROXY_VIP6=fd00::200

# Real IPv6 address of Node A
NODE_A_IP6=fd00::10

# Real IPv6 address of Node B
NODE_B_IP6=fd00::11

# IPv6 address of the dedicated NFS storage server (PC 3)
NFS_SERVER_IP6=fd00::5

# ── Keepalived ────────────────────────────────────────────────────────────────
# Shared authentication password for VRRP v2/IPv4 (keep this private!).
# Note: VRRPv3 (used for IPv6 VIP) does NOT support AUTH_PASS.
KEEPALIVED_AUTH_PASS=CHANGE_ME_KEEPALIVED_PASSWORD

# ── Minecraft ─────────────────────────────────────────────────────────────────
# Minecraft server version
MC_VERSION=1.21.4

# Memory allocated to each Minecraft JVM
MC_MEMORY=4G
