# =============================================================================
# .env.example – Environment variable template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#
#   cp .env.example .env
#   # edit .env with your actual values
#
# Machine layout:
#   PC 1 (Node A) – Minecraft Primary  + Velocity Proxy 1  – 192.168.1.10
#   PC 2 (Node B) – Minecraft Backup   + Velocity Proxy 2  – 192.168.1.11
#   PC 3 (NFS)    – Dedicated storage  (no game processes)  – 192.168.1.5
# =============================================================================

# ── Velocity ──────────────────────────────────────────────────────────────────
# Shared secret between Velocity proxies and Minecraft backends.
# Generate with:  openssl rand -hex 16
VELOCITY_SECRET=CHANGE_ME_32_CHAR_SECRET_HERE

# ── Network ───────────────────────────────────────────────────────────────────
# Public Virtual IP managed by Keepalived (what players / DNS point to).
# This VIP floats between Node A and Node B.
PROXY_VIP=192.168.1.200

# Real IP of Node A (primary Minecraft + Proxy 1)
NODE_A_IP=192.168.1.10

# Real IP of Node B (backup Minecraft + Proxy 2)
NODE_B_IP=192.168.1.11

# IP of the dedicated NFS storage server (PC 3)
NFS_SERVER_IP=192.168.1.5

# ── Keepalived ────────────────────────────────────────────────────────────────
# Shared authentication password for VRRP (keep this private!)
KEEPALIVED_AUTH_PASS=CHANGE_ME_KEEPALIVED_PASSWORD

# ── Minecraft ─────────────────────────────────────────────────────────────────
# Minecraft server version
MC_VERSION=1.21.4

# Memory allocated to each Minecraft JVM
MC_MEMORY=4G
