# =============================================================================
# .env.example – Environment variable template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#
#   cp .env.example .env
#   # edit .env with your actual values
# =============================================================================

# ── Velocity ──────────────────────────────────────────────────────────────────
# Shared secret between Velocity proxy and Minecraft backends.
# Generate with:  openssl rand -hex 16
VELOCITY_SECRET=CHANGE_ME_32_CHAR_SECRET_HERE

# ── Network ───────────────────────────────────────────────────────────────────
# Virtual IP managed by Keepalived (what players connect to)
VIP=192.168.1.100

# Real IP of Node A (primary)
NODE_A_IP=192.168.1.10

# Real IP of Node B (backup)
NODE_B_IP=192.168.1.11

# IP of Velocity proxy
PROXY_IP=192.168.1.20

# IP of NFS server
NFS_SERVER_IP=192.168.1.5

# ── Keepalived ────────────────────────────────────────────────────────────────
# Shared authentication password for VRRP (keep this private!)
KEEPALIVED_AUTH_PASS=CHANGE_ME_KEEPALIVED_PASSWORD

# ── Minecraft ─────────────────────────────────────────────────────────────────
# Minecraft server version
MC_VERSION=1.21.4

# Memory allocated to each Minecraft JVM
MC_MEMORY=4G
