# =============================================================================
# IPv4-Lab – Environment variables for the test setup
# =============================================================================
# Copy to:
#   cp test/ipv4-lab/.env.example test/ipv4-lab/.env
#
# This file is used by the IPv4-only compose files in test/ipv4-lab/compose/.
# =============================================================================

# Shared secret between Velocity and the Paper backends.
# Must match `forwarding_secret` in both velocity-node-*.toml files.
VELOCITY_SECRET=CHANGE_ME_32_CHAR_SECRET_HERE

# Keepalived IPv4 authentication password for the lab config.
# Set the same value manually in keepalived/node-a.conf and node-b.conf.
KEEPALIVED_AUTH_PASS=labpass1

# IPv4 addresses used by the lab
PROXY_VIP=192.168.1.200
NODE_A_IP=192.168.1.10
NODE_B_IP=192.168.1.11
NFS_SERVER_IP=192.168.1.5

# Host network interface carrying the VIP on Node A / Node B
NET_IFACE=eth0

# Public test domain (A record only in the IPv4 phase)
PUBLIC_DOMAIN=play.test.local

# Minecraft tuning for the lab
MC_VERSION=1.21.4
MC_MEMORY=2G

